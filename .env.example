# Copy this file to .env.local and add your API keys
ANTHROPIC_API_KEY=your-api-key-here

# Optional: ElevenLabs API key for AI voices
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# Optional: Password to protect the site (leave empty for no protection)
SITE_PASSWORD=

# Comma-separated list of origins allowed to call /api/stream
# Example: https://claude.dj,https://www.claude.dj
ALLOWED_ORIGINS=

# Cloudflare Turnstile — bot challenge on chat submissions.
# Both must be set for verification to be enforced (otherwise it's skipped).
# Site key is public, secret key is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis — distributed rate limiting for /api/stream.
# When set, replaces the in-memory rate limit with: 3 req/10min and 15 req/day per IP.
# When unset, falls back to per-instance in-memory limit (10 req/min).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
